{
    "workbench.colorCustomizations": {
        "titleBar.activeBackground": "#003cff99"
    },
    "ROS2.distro": "lyrical",
    "python.autoComplete.extraPaths": [
        "/opt/ros/lyrical/opt/gz_sim_vendor/lib/python",
        "/opt/ros/lyrical/opt/gz_transport_vendor/lib/python",
        "/opt/ros/lyrical/opt/sdformat_vendor/lib/python",
        "/opt/ros/lyrical/opt/gz_msgs_vendor/lib/python",
        "/opt/ros/lyrical/opt/gz_math_vendor/lib/python",
        "/opt/ros/lyrical/lib/python3.14/site-packages"
    ],
    "python.analysis.extraPaths": [
        "/opt/ros/lyrical/opt/gz_sim_vendor/lib/python",
        "/opt/ros/lyrical/opt/gz_transport_vendor/lib/python",
        "/opt/ros/lyrical/opt/sdformat_vendor/lib/python",
        "/opt/ros/lyrical/opt/gz_msgs_vendor/lib/python",
        "/opt/ros/lyrical/opt/gz_math_vendor/lib/python",
        "/opt/ros/lyrical/lib/python3.14/site-packages"
    ],
    "C_Cpp.workspaceParsingPriority": "low",
    "C_Cpp.intelliSenseMemoryLimit": 2048,
    "C_Cpp.intelliSenseCacheSize": 5120,
    "search.exclude": {
        ".pio": true
    },
    "files.watcherExclude": {
        ".pio/**": true
    },
    "C_Cpp.files.exclude": {
        ".pio/build/**": true
    },
    "cmake.ignoreCMakeListsMissing": true
}